[global]
    frame_color = "{{colors.outline_variant.default.hex}}03"

[urgency_low]
    background = "{{colors.surface_container.default.hex}}80"
    foreground = "{{colors.on_surface.default.hex}}E6"
    frame_color = "{{colors.surface_container.default.hex}}03"

[urgency_normal]
    background = "{{colors.surface.default.hex}}80"
    foreground = "{{colors.on_surface.default.hex}}E6"
    frame_color = "{{colors.surface.default.hex}}03"

[urgency_critical]
    background = "{{colors.error_container.default.hex}}"
    foreground = "{{colors.on_error_container.default.hex}}"
    frame_color = "{{colors.error.default.hex}}"
