# ~/.config/fish/secrets.fish.example
#
# INSTRUCCIONES:
#   1. Copia este archivo a secrets.fish:
#      cp ~/.config/fish/secrets.fish.example ~/.config/fish/secrets.fish
#   2. Edita con tus claves reales:
#      $EDITOR ~/.config/fish/secrets.fish
#   3. NUNCA commitees secrets.fish al repo (está en .gitignore)
#
# El archivo secrets.fish es cargado automáticamente por config.fish si existe.
# Si no existe, config.fish funciona normalmente sin secrets.

# ┌────────────────────────────────────────────────────────────┐
# │ API KEYS — ejemplos (reemplaza con tus claves reales)       │
# └────────────────────────────────────────────────────────────┘

# Anthropic API (Claude)
# set -gx ANTHROPIC_API_KEY "sk-ant-api03-xxxxx"

# OpenAI
# set -gx OPENAI_API_KEY "sk-xxxxx"

# GitHub
# set -gx GITHUB_TOKEN "ghp_xxxxx"

# AWS
# set -gx AWS_ACCESS_KEY_ID "xxxxx"
# set -gx AWS_SECRET_ACCESS_KEY "xxxxx"

# ┌────────────────────────────────────────────────────────────┐
# │ OTROS SECRETS / TOKENS                                      │
# └────────────────────────────────────────────────────────────┘

# Tokens personalizados
# set -gx MY_CUSTOM_TOKEN "xxxxx"

# Contraseñas de servicios
# set -gx MY_DB_PASSWORD "xxxxx"

# SSH agent custom path (si usas uno distinto)
# set -gx SSH_AUTH_SOCK "$HOME/.ssh/agent.sock"
