# Plantilla de secretos para fish — NO pongas claves reales en este archivo.
#
# En la máquina nueva:
#   cp ~/.config/fish/secrets.fish.example ~/.config/fish/secrets.fish
#   # edita secrets.fish con tus claves reales (ese archivo está en .gitignore)
#
# Ejemplo:
# set -gx ANTHROPIC_API_KEY "tu_clave_aqui"
