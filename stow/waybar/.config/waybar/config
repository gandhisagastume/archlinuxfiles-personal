{
    "layer": "top",
    "output": ["*"],
    "position": "top",
    "height": 35,
    "spacing": 0,
    "reload_style_on_change": true,

    "modules-left": [
        "hyprland/workspaces",
        "wlr/taskbar",
        "custom/cava_mviz"
    ],

    "modules-center": [
        "clock",
        "mpris"
    ],

    "modules-right": [
        "group/audio",
        "group/laptop",
        "custom/updates",
        "tray",
        "group/power"
    ],

    "hyprland/workspaces": {
        "active-only": false,
        "all-outputs": true,
        "format": "{icon}",
        "show-special": false,
        "on-click": "activate",
        "on-scroll-up": "hyprctl dispatch workspace e+1",
        "on-scroll-down": "hyprctl dispatch workspace e-1",
        "persistent-workspaces": {
            "*": 5
        },
        "format-icons": {
            "active": "´ćĺ",
            "default": "´äî"
        }
    },

    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 18,
        "all-outputs": false,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close",
        "ignore-list": [
            "rofi",
            "wofi"
        ]
    },

    "mpris": {
        "format": "{player_icon} {dynamic}",
        "format-paused": "{status_icon} <i>{dynamic}</i>",
        "on-click-middle": "playerctl play-pause",
        "on-click": "playerctl previous",
        "on-click-right": "playerctl next",
        "player-icons": {
            "default": "´ÇŁ",
            "firefox": "´ëę",
            "spotify": "´ć╝",
            "mpv": "ˇ░É╣",
            "vlc": "ˇ░Ľ╝"
        },
        "status-icons": {
            "paused": "ˇ░ÉÄ",
            "playing": "´üő",
            "stopped": "´üŹ"
        },
        "dynamic-order": ["artist", "title"],
        "max-length": 50,
        "tooltip": true,
        "tooltip-format": "{status_icon} {dynamic}"
    },

    "clock": {
        "interval": 1,
        "format": "´ÇŚ {:%I:%M %p}",
        "format-alt": "´ÇŚ {:%H:%M  ´ü│ %Y, %d %B, %A}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "year",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "format": {
                "months": "<span color='#ffead3'><b>{}</b></span>",
                "days": "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
                "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
                "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },

    "backlight": {
        "interval": 2,
        "device": "intel_backlight",
        "format": "{icon}",
        "format-icons": ["ţĆĽ", "ţĆŚ", "ţĆÜ", "ˇ░âŁ", "ˇ░â×", "ˇ░âč", "ˇ░âá"],
        "tooltip-format": "backlight {percent}%",
        "on-scroll-up": "$HOME/.local/share/bin/brightnesscontrol.sh i 1",
        "on-scroll-down": "$HOME/.local/share/bin/brightnesscontrol.sh d 1",
        "smooth-scrolling-threshold": 1
    },

    "battery": {
        "full-at": 100,
        "design-capacity": false,
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "´âž {capacity}%",
        "format-plugged": "ˇ▒śľ {capacity}%",
        "format-full": "{icon} Full",
        "format-alt": "{icon} {time}",
        "format-icons": [
            "ˇ░éÄ", "ˇ░ü║", "ˇ░ü╗", "ˇ░ü╝", "ˇ░üŻ", "ˇ░üż", "ˇ░ü┐", "ˇ░éÇ", "ˇ░éü", "ˇ░éé", "ˇ░ü╣"
        ],
        "format-time": "{H}h {M}min",
        "tooltip": true,
        "tooltip-format": "{timeTo} {power}w"
    },

    "bluetooth": {
        "format": "´Őô",
        "format-disabled": "ˇ░é│",
        "format-connected": "ˇ░é▒ {num_connections}",
        "tooltip-format": "´Őô {device_alias}",
        "tooltip-format-connected": "{device_enumerate}",
        "tooltip-format-enumerate-connected": "´Őô {device_alias} ˇ░éä{device_battery_percentage}%",
        "tooltip": true,
        "on-click": "blueman-manager"
    },

    "network": {
        "format": "{ifname}",
        "format-wifi": "{icon}",
        "format-ethernet": "ˇ░îś",
        "format-disconnected": "ˇ░îÖ",
        "tooltip-format": "{ipaddr} ´ä╣ {bandwidthUpBits} ´ä║ {bandwidthDownBits}",
        "format-linked": "ˇ░łü {ifname} (No IP)",
        "tooltip-format-wifi": "{essid} {icon} {signalStrength}%",
        "tooltip-format-ethernet": "{ifname} ˇ░îś",
        "tooltip-format-disconnected": "ˇ░îÖ Disconnected",
        "max-length": 30,
        "format-icons": ["ˇ░Ą»", "ˇ░Ąč", "ˇ░Ąó", "ˇ░Ąą", "ˇ░ĄĘ"],
        "on-click-right": "$HOME/.local/share/bin/wifi-manager.sh"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon} ˇ░é░ {volume}%",
        "format-muted": "ˇ░ľü",
        "format-icons": {
            "headphone": "´Çą",
            "hands-free": "´Çą",
            "headset": "´ľÉ",
            "phone": "´éĽ",
            "portable": "´éĽ",
            "car": "´ć╣",
            "default": ["´ÇŽ", "´Çž", "ˇ░Ľż", "´ÇĘ"]
        },
        "scroll-step": 5,
        "on-click": "$HOME/.local/share/bin/volumecontrol.sh -o m",
        "on-click-right": "pavucontrol -t 3",
        "on-scroll-up": "$HOME/.local/share/bin/volumecontrol.sh -o i",
        "on-scroll-down": "$HOME/.local/share/bin/volumecontrol.sh -o d",
        "tooltip-format": "{icon} {desc} | {volume}%",
        "smooth-scrolling-threshold": 1
    },

    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "´ä░ {volume}%",
        "format-source-muted": "´ä▒",
        "on-click": "$HOME/.local/share/bin/volumecontrol.sh -i m",
        "on-click-right": "pavucontrol -t 4",
        "on-scroll-up": "$HOME/.local/share/bin/volumecontrol.sh -i i",
        "on-scroll-down": "$HOME/.local/share/bin/volumecontrol.sh -i d",
        "tooltip-format": "{source_desc} | {source_volume}%",
        "scroll-step": 5
    },

    "custom/updates": {
        "exec": "$HOME/.local/share/bin/systemupdate.sh",
        "return-type": "json",
        "format": "´ÇÖ {}",
        "interval": 86400,
        "signal": 20,
        "on-click": "hyprctl dispatch exec '$HOME/.local/share/bin/systemupdate.sh up'",
        "tooltip": true
    },

    "tray": {
        "icon-size": 18,
        "spacing": 6
    },

    "idle_inhibitor": {
        "tooltip": true,
        "tooltip-format-activated": "Idle inhibitor active",
        "tooltip-format-deactivated": "Idle inhibitor not active",
        "format": "{icon}",
        "format-icons": {
            "activated": "´ü«",
            "deactivated": "´ü░"
        }
    },

    "custom/menu": {
        "format": " ´ŹÖ ",
        "on-click": "pkill rofi || $HOME/.local/share/bin/rofilaunch-nord.sh",
        "on-click-middle": "$HOME/.config/hypr/scripts/wppicker.sh",
        "on-click-right": "$HOME/.config/hypr/scripts/WaybarLayout.sh",
        "tooltip": true,
        "tooltip-format": "Left: App Launcher\nMiddle: Wallpaper Picker\nRight: Waybar Layout"
    },

    "custom/cava_mviz": {
        "exec": "$HOME/.config/hypr/scripts/waybarcava.sh",
        "format": "{}"
    },

    "custom/cycle_wall": {
        "format": "´Çż",
        "on-click": "$HOME/.config/hypr/scripts/wppicker.sh",
        "on-click-right": "$HOME/.config/hypr/scripts/wallpaper-cycle.sh n",
        "tooltip": true,
        "tooltip-format": "Left: Wallpaper Menu\nRight: Next Wallpaper"
    },

    "custom/lock": {
        "format": "ˇ░îż",
        "on-click": "hyprlock",
        "tooltip": true,
        "tooltip-format": "Screen Lock (hyprlock)"
    },

    "custom/power": {
        "format": "ÔĆ╗",
        "on-click": "$HOME/.local/share/bin/logoutlaunch.sh",
        "tooltip": true,
        "tooltip-format": "Logout Menu"
    },

    "group/audio": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 500,
            "children-class": "pulseaudio",
            "transition-left-to-right": true
        },
        "modules": [
            "pulseaudio",
            "pulseaudio#microphone"
        ]
    },

    "group/laptop": {
        "orientation": "inherit",
        "modules": [
            "battery"
        ]
    },

    "group/power": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 500,
            "children-class": "drawer-child",
            "transition-left-to-right": false
        },
        "modules": [
            "custom/power",
            "custom/lock",
            "idle_inhibitor",
            "custom/cycle_wall"
        ]
    }
}
