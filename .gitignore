# .gitignore para archlinuxfiles-personal
# Este archivo previene que archivos generados/runtime/máquina-específicos
# se suban al repo.

# ┌────────────────────────────────────────────────────────────┐
# │ CACHE & RUNTIME                                            │
# └────────────────────────────────────────────────────────────┘
.cache/
__pycache__/
*.pyc
*.pyo
.python-version

# ┌────────────────────────────────────────────────────────────┐
# │ BACKUPS & LOCK                                             │
# └────────────────────────────────────────────────────────────┘
cfg_backups/
*_backup/
*_bak/
*.bak
*.orig
*.lock
*.swp
*.swo
*~

# ┌────────────────────────────────────────────────────────────┐
# │ SESSION & RUNTIME                                          │
# └────────────────────────────────────────────────────────────┘
session/
pulse/
dconf/
procps/
.Trash-*/

# ┌────────────────────────────────────────────────────────────┐
# │ HISTORY                                                     │
# └────────────────────────────────────────────────────────────┘
.bash_history
.viminfo
.history
*.history
fish_history
python_history
lesshst
viminfo

# ┌────────────────────────────────────────────────────────────┐
# │ EDITORES / IDEs                                            │
# └────────────────────────────────────────────────────────────┘
# VS Code / Code OSS
stow/code/.config/Code - OSS/Cache/
stow/code/.config/Code - OSS/CachedData/
stow/code/.config/Code - OSS/CachedProfilesData/
stow/code/.config/Code - OSS/Code Cache/
stow/code/.config/Code - OSS/Crashpad/
stow/code/.config/Code - OSS/DawnGraphiteCache/
stow/code/.config/Code - OSS/DawnWebGPUCache/
stow/code/.config/Code - OSS/Dictionaries/
stow/code/.config/Code - OSS/GPUCache/
stow/code/.config/Code - OSS/Local State
stow/code/.config/Code - OSS/Local Storage/
stow/code/.config/Code - OSS/Network Persistent State
stow/code/.config/Code - OSS/Preferences
stow/code/.config/Code - OSS/Session Storage/
stow/code/.config/Code - OSS/Shared Dictionary/
stow/code/.config/Code - OSS/Trust Tokens*
stow/code/.config/Code - OSS/User/globalStorage/
stow/code/.config/Code - OSS/User/workspaceStorage/
stow/code/.config/Code - OSS/User/History/
stow/code/.config/Code - OSS/languagepacks.json
stow/code/.config/Code - OSS/machineid
stow/code/.config/Code - OSS/DIPS

# ┌────────────────────────────────────────────────────────────┐
# │ SECRETS — NUNCA VERSIONAR                                  │
# └────────────────────────────────────────────────────────────┘
secrets.fish
*.secret
*.key
*.pem
.env
.envrc
*.gpg

# ┌────────────────────────────────────────────────────────────┐
# │ MATUGEN (regenerado por máquina)                          │
# └────────────────────────────────────────────────────────────┘
colors.conf
colors.css
colors.rasi
dunstrc_colors
hyprlock_colors.conf
hyprland_colors.conf
kitty-colors.conf
gtk-colors.css
fastfetch-config.jsonc
dunst-colors
rofi-colors.rasi

# ┌────────────────────────────────────────────────────────────┐
# │ WALLPAPER GENERATED (por máquina)                         │
# └────────────────────────────────────────────────────────────┘
current_wallpaper
hyprlock_wallpaper.png
wall.set
nvidia.conf
.cache/wall.thmb
.cache/wall.blur

# ┌────────────────────────────────────────────────────────────┐
# │ OS & TEMPORALES                                            │
# └────────────────────────────────────────────────────────────┘
.DS_Store
Thumbs.db
desktop.ini
*.tmp
*.log
logs/
/tmp/
*.swp

# ┌────────────────────────────────────────────────────────────┐
# │ BOOTSTRAP TEMP FILES                                       │
# └────────────────────────────────────────────────────────────┘
_official.txt
_aur.txt
bootstrap.log

# ┌────────────────────────────────────────────────────────────┐
# │ PACKAGE MANAGEMENT                                         │
# └────────────────────────────────────────────────────────────┘
paru/
yay/
.go/
*.pkg.tar.zst

# ┌────────────────────────────────────────────────────────────┐
# │ BINARIOS / COMPILADOS                                      │
# └────────────────────────────────────────────────────────────┘
*.o
*.so
*.a
*.so.*
node_modules/
__pycache__/
__target__/
target/

# ┌────────────────────────────────────────────────────────────┐
# │ ARCHIVOS GRANDES (excede límite GitHub 100MB)              │
# └────────────────────────────────────────────────────────────┘
# vagabond.gif = 199MB (excede 100MB de GitHub)
vagabond.gif
# GIFs del wallpaper canónico (grandes, se copian manualmente)
/stow/wallpaper/Wallpapers/*.gif
*.gif.lfs

# ┌────────────────────────────────────────────────────────────┐
# │ OTROS                                                      │
# └────────────────────────────────────────────────────────────┘
*.pid
*.sock
*.socket
nohup.out
core.*
core
